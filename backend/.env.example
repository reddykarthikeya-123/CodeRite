# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database
SQL_ECHO=false

# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Deterministic LLM Settings
LLM_DETERMINISTIC_MODE=true
LLM_SEED=42
LLM_TOP_P=1.0
LLM_TOP_K=1
LLM_TEMPERATURE=0.0
LLM_MAX_CONCURRENCY=1
LLM_CACHE_MODE=exact_input
LLM_CACHE_MAX_AGE_DAYS=30
LLM_VISION_MODE=auto
LLM_VISION_MODEL_ALLOWLIST=gpt-4o,gpt-4.1,gemini-1.5,gemini-2.0,gemini-2.5,llava,vision
LLM_VISION_MODEL_BLOCKLIST=
LLM_VISION_MAX_IMAGES_PER_REQUEST=6

# Security
SECRET_KEY=your_secret_key_for_jwt
ENCRYPTION_KEY=your_fernet_encryption_key

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_DEFAULT=10/minute
RATE_LIMIT_STRICT=5/minute

# File Upload
MAX_FILE_SIZE=52428800

# OCR Configuration
TESSERACT_PATH=C:\Program Files\Tesseract-OCR
POPPLER_PATH=C:\poppler\poppler-24.08.0\Library\bin
PDF_OCR_MODE=always
PDF_OCR_MIN_TEXT_CHARS_PER_PAGE=120
PDF_OCR_MAX_PAGES=100

# DOCX Pagination (LibreOffice)
SOFFICE_PATH=/usr/bin/soffice
DOCX_CONVERT_TIMEOUT_SEC=90
DOCX_PAGINATION_REQUIRED=false
