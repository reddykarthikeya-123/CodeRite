# Backend Environment Variables
# Copy this file to .env and configure for your environment

# =============================================================================
# DATABASE (Required)
# =============================================================================
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/dbname"

# =============================================================================
# AI SERVICES
# =============================================================================
# Ollama local AI service (optional, defaults to http://localhost:11434)
OLLAMA_BASE_URL="http://localhost:11434"

# =============================================================================
# OCR & PDF PROCESSING PATHS
# =============================================================================
# These are only used on Windows. On Linux, the system will use the 
# tesseract and poppler installed via apt (sudo apt install tesseract-ocr poppler-utils)

# Windows: Tesseract OCR installation path
TESSERACT_PATH="C:\Program Files\Tesseract-OCR"

# Windows: Poppler utilities for PDF to image conversion
POPPLER_PATH="C:\poppler\poppler-24.08.0\Library\bin"

# Linux examples (uncomment if needed, usually not required):
# TESSERACT_PATH="/usr/bin/tesseract"
# POPPLER_PATH="/usr/bin"

# =============================================================================
# NOTES ON DEPENDENCIES
# =============================================================================
# Windows: python-magic requires libmagic DLL. Download from:
#   https://github.com/pidydx/libmagic-win64
#   Extract and add to PATH, or MIME validation will be skipped gracefully
#
# Linux: Install with: sudo apt install libmagic1
