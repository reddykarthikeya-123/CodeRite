
# === DATABASE CONFIGURATION ===
# PostgreSQL connection (required)
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL="postgresql+asyncpg://postgres:1234@localhost:5432/CodeRite"

# === AI SERVICES ===
# Ollama local AI service (optional, defaults to http://localhost:11434)
OLLAMA_BASE_URL="http://localhost:11434"

# === CORS CONFIGURATION ===
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# === OCR & PDF PROCESSING (Windows only) ===
# Tesseract OCR installation path (optional, defaults to C:\Program Files\Tesseract-OCR)
TESSERACT_PATH="C:\Program Files\Tesseract-OCR"

# Poppler utilities for PDF to image conversion (optional, defaults to C:\poppler\poppler-24.08.0\Library\bin)
POPPLER_PATH="C:\poppler\poppler-24.08.0\Library\bin"

# === VISION MODE (document image analysis) ===
# on | off | auto
LLM_VISION_MODE="on"

# === PRODUCTION SERVER CONFIGURATION (129.213.157.87 / rite.digital) ===
# Uncomment and modify these for production deployment
# DATABASE_URL="postgresql+asyncpg://postgres:145913_Mss@129.213.157.87:5000/coderite"
# OLLAMA_BASE_URL="http://129.213.157.87:11434"
